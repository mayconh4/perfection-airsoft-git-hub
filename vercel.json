{
  "rewrites": [
    { "source": "/drop",     "destination": "/api/og?type=drop-list" },
    { "source": "/eventos",  "destination": "/api/og?type=eventos-list" },
    { "source": "/produtos", "destination": "/api/og?type=produtos-list" },
    { "source": "/marcas",   "destination": "/api/og?type=marcas-list" },
    {
      "source": "/drop/(.*)",
      "destination": "/api/og?type=drop&slug=$1"
    },
    {
      "source": "/eventos/(.*)",
      "destination": "/api/og?type=eventos&slug=$1"
    },
    {
      "source": "/produto/(.*)",
      "destination": "/api/og?type=produto&slug=$1"
    },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
