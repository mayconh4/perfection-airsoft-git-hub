{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/og"
    },
    {
      "source": "/drop/(.*)",
      "destination": "/api/og"
    },
    {
      "source": "/eventos/(.*)",
      "destination": "/api/og"
    },
    {
      "source": "/produto/(.*)",
      "destination": "/api/og"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
