{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/og",
      "missing": [{ "type": "header", "key": "x-og-internal" }]
    },
    {
      "source": "/drop",
      "destination": "/api/og?type=drop-list"
    },
    {
      "source": "/drop/(.*)",
      "destination": "/api/og?type=drop&slug=$1"
    },
    {
      "source": "/eventos/(.*)",
      "destination": "/api/og?type=eventos&slug=$1"
    },
    {
      "source": "/produto/(.*)",
      "destination": "/api/og?type=produto&slug=$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
