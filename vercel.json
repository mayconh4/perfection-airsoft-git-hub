{
  "rewrites": [
    { "source": "/drop/(.*)",    "destination": "/api/og?type=drop&slug=$1" },
    { "source": "/eventos/(.*)", "destination": "/api/og?type=eventos&slug=$1" },
    { "source": "/produto/(.*)", "destination": "/api/og?type=produto&slug=$1" },
    { "source": "/blog/(.*)",    "destination": "/api/og?type=blog&slug=$1" },
    { "source": "/sitemap.xml",  "destination": "/api/sitemap" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ],
  "functions": {
    "api/og.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
