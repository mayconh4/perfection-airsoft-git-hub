{
  "rewrites": [
    {
      "source": "/drop/(.*)",
      "has": [
        { "type": "header", "key": "user-agent", "value": "(.*)(bot|facebookexternalhit|whatsapp|telegram|twitterbot|googlebot|bingbot)(.*)" }
      ],
      "destination": "/api/og-proxy"
    },
    {
      "source": "/eventos/(.*)",
      "has": [
        { "type": "header", "key": "user-agent", "value": "(.*)(bot|facebookexternalhit|whatsapp|telegram|twitterbot|googlebot|bingbot)(.*)" }
      ],
      "destination": "/api/og-proxy"
    },
    {
      "source": "/produto/(.*)",
      "has": [
        { "type": "header", "key": "user-agent", "value": "(.*)(bot|facebookexternalhit|whatsapp|telegram|twitterbot|googlebot|bingbot)(.*)" }
      ],
      "destination": "/api/og-proxy"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
